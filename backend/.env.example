# Backend Environment Variables
# Copy this to .env and fill in with your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=combat_os
DB_USER=postgres
DB_PASSWORD=postgres

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRY=7d

# Modules (true/false to enable/disable)
MODULE_PERSONNEL=true
MODULE_QR_SCAN=true
MODULE_EXIT_FORM=true
MODULE_PHOTO_UPLOAD=true
MODULE_LOGISTICS=false
MODULE_SECURITY=false
MODULE_TRAINING=false

# GPS Validation
GPS_VALIDATION_ENABLED=true
GPS_RADIUS_METERS=100

# Storage (local, supabase, or cloudinary)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# CORS
CORS_ORIGIN=http://localhost:5174
