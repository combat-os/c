# Backend Environment Variables
# Copy this to .env and fill in with your values

# Database
DB_HOST=REPLACE_WITH_YOUR_VALUE
DB_PORT=5432
DB_NAME=REPLACE_WITH_YOUR_VALUE
DB_USER=REPLACE_WITH_YOUR_VALUE
DB_PASSWORD=REPLACE_WITH_YOUR_VALUE

# Server
PORT=3000
NODE_ENV=development

# JWT
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET_MINIMUM_64_CHARS
JWT_EXPIRY=7d

# Modules (true/false to enable/disable)
MODULE_PERSONNEL=true
MODULE_QR_SCAN=true
MODULE_EXIT_FORM=true
MODULE_PHOTO_UPLOAD=true
MODULE_LOGISTICS=false
MODULE_SECURITY=false
MODULE_TRAINING=false

# GPS Validation
GPS_VALIDATION_ENABLED=true
GPS_RADIUS_METERS=100

# Storage (local, supabase, or cloudinary)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# CORS
CORS_ORIGIN=http://localhost:5174
